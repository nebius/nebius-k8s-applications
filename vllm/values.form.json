{
  "type": "object",
  "required": true,
  "viewSpec": {
    "type": "base",
    "order": [
      "mk8sCluster",
      "general",
      "global",
      "gpuPlatform",
      "gpuPerWorker",
      "vllm",
      "gradio-ui"
    ],
    "layout": ""
  },
  "defaultValue": {
    "global": {
      "model": "Qwen/Qwen2.5-7B-Instruct"
    },
    "gpuPlatform": "NVIDIA® L40S with Intel Ice Lake",
    "gradio-ui": {
      "enabled": true,
"secret": {
        "env": {
          "AUTH_PASSWORD": null,
          "AUTH_USER": null
        }
      }
    },
    "gpuPerWorker": "1",
    "vllm": {
      "env": {
        "HF_TOKEN": null
      },
      "hfCache": {
        "enabled": true
      },
      "replicas": 1
    }
  },
  "properties": {
    "mk8sCluster": {
      "type": "object",
      "required": true,
      "viewSpec": {
        "type": "mk8s_cluster"
      }
    },
    "general": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "layout": "section",
        "layoutTitle": "General"
      },
      "defaultValue": {},
      "properties": {
        "appname": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Application name"
          },
          "defaultValue": "vllm"
        },
        "namespace": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Namespace"
          },
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "patternError": "namespace must consist of lower case alphanumeric characters or '-', and must start and end with an alphanumeric character (e.g. 'my-name',  or '123-abc', regex used for validation is ^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "defaultValue": "vllm"
        }
      }
    },
    "global": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "order": [
          "model"
        ],
        "layout": ""
      },
      "properties": {
        "model": {
          "type": "string",
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Model for vLLM engine",
            "layoutDescription": "Model id from Hugging Face like meta-llama/Meta-Llama-3-8B-Instruct\nMake sure you have access to that model.\n"
          }
        }
      }
    },
    "gpuPlatform": {
      "type": "string",
      "required": true,
      "viewSpec": {
        "type": "select",
        "layout": "row",
        "layoutTitle": "GPU Platform",
        "layoutDescription": "Please select GPU platform that is present in K8s cluster."
      },
      "enum": [
        "NVIDIA® H100 NVLink with Intel Sapphire Rapids",
        "NVIDIA® H200 NVLink with Intel Sapphire Rapids",
        "NVIDIA® B200 NVLink with Intel Emerald Rapids",
        "NVIDIA® L40S with Intel Ice Lake",
        "NVIDIA® L40S with AMD Genoa"
      ]
    },
    "gradio-ui": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "order": [
          "enabled",
          "secret"
        ],
        "layout": ""
      },
      "properties": {
        "enabled": {
          "type": "boolean",
          "viewSpec": {
            "disabled": false,
            "layout": "row",
            "layoutTitle": "Enable Gradio UI",
            "type": "switch"
          }
        },
        "secret": {
          "type": "object",
          "viewSpec": {
            "type": "base",
            "order": [
              "env"
            ],
            "layout": ""
          },
          "defaultValue": {
            "env": {
              "AUTH_PASSWORD": null,
              "AUTH_USER": null
            }
          },
          "properties": {
            "env": {
              "type": "object",
              "viewSpec": {
                "type": "base",
                "order": [
                  "AUTH_USER",
                  "AUTH_PASSWORD"
                ],
                "layout": ""
              },
              "defaultValue": {
                "AUTH_PASSWORD": null,
                "AUTH_USER": null
              },
              "properties": {
                "AUTH_PASSWORD": {
                  "type": "string",
                  "viewSpec": {
                    "disabled": false,
                    "generateRandomValueButton": true,
                    "layout": "row",
                    "layoutTitle": "Gradio password",
                    "type": "password"
                  }
                },
                "AUTH_USER": {
                  "type": "string",
                  "viewSpec": {
                    "type": "base",
                    "layout": "row",
                    "layoutTitle": "Gradio username"
                  }
                }
              }
            }
          }
        }
      }
    },
    "gpuPerWorker": {
      "type": "string",
      "viewSpec": {
        "type": "select",
        "layout": "row",
        "layoutTitle": "Number of GPU per single vLLM replica"
      },
      "enum": [
        "1",
        "2",
        "3",
        "4",
        "5",
        "6",
        "7",
        "8"
      ]
    },
    "vllm": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "order": [
          "replicas",
          "env",
          "config",
          "hfCache"
        ],
        "layout": ""
      },
      "properties": {
        "replicas": {
          "type": "number",
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Number of vLLM replicas"
          }
        },
        "env": {
          "type": "object",
          "viewSpec": {
            "type": "base",
            "order": [
              "HF_TOKEN"
            ],
            "layout": ""
          },
          "defaultValue": {
            "HF_TOKEN": null
          },
          "properties": {
            "HF_TOKEN": {
              "type": "string",
              "viewSpec": {
                "disabled": false,
                "layout": "row",
                "layoutDescription": "Could be generated here https://huggingface.co/settings/tokens",
                "layoutTitle": "Hugging Face access token",
                "type": "password"
              }
            }
          }
        },
        "hfCache": {
          "type": "object",
          "viewSpec": {
            "type": "base",
            "order": [
              "enabled"
            ],
            "layout": ""
          },
          "properties": {
            "enabled": {
              "type": "boolean",
              "viewSpec": {
                "disabled": false,
                "layout": "row",
                "layoutDescription": "This could prevent re-download models from HF across restarts",
                "layoutTitle": "Enable Hugging Face cache",
                "type": "switch"
              }
            }
          }
        },
        "config": {
          "type": "object",
          "viewSpec": {
            "type": "base",
            "order": [
              "pipeline-parallel-size",
              "max-model-len"
            ],
            "layout": ""
          },
          "defaultValue": {
            "pipeline-parallel-size": 1
          },
          "properties": {
            "pipeline-parallel-size": {
              "type": "number",
              "viewSpec": {
                "disabled": false,
                "layout": "row",
                "layoutTitle": "Number of workers required to run single vLLM replicas",
                "type": "base"
              }
            },
            "max-model-len": {
              "type": "number",
              "viewSpec": {
                "disabled": false,
                "layout": "row",
                "layoutTitle": "Model context length",
                "type": "base"
              }
            }
          }
        }
      }
    }
  }
}
