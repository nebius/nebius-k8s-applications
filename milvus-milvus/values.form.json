{
  "type": "object",
  "viewSpec": {
    "type": "base",
    "order": [
      "mk8sCluster",
      "general",
      "gpu_number",
      "cluster",
      "pulsar",
      "minio",
      "etcd"
    ],
    "layout": ""
  },
  "defaultValue": {
    "cluster": {
      "enabled": false
    },
    "etcd": {
      "replicaCount": "1"
    },
    "gpu_number": 0,
    "minio": {
      "mode": "standalone"
    },
    "pulsar": {
      "enabled": false
    }
  },
  "properties": {
    "mk8sCluster": {
      "type": "object",
      "required": true,
      "viewSpec": {
        "type": "mk8s_cluster"
      }
    },
    "general": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "layout": "section",
        "layoutTitle": "General"
      },
      "defaultValue": {},
      "properties": {
        "appname": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Application name"
          },
          "defaultValue": "milvus"
        },
        "namespace": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Namespace"
          },
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "patternError": "namespace must consist of lower case alphanumeric characters or '-', and must start and end with an alphanumeric character (e.g. 'my-name',  or '123-abc', regex used for validation is ^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "defaultValue": "milvus"
        }
      }
    },
    "cluster": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "order": [
          "enabled"
        ],
        "layout": ""
      },
      "properties": {
        "enabled": {
          "type": "boolean",
          "viewSpec": {
            "disabled": false,
            "layout": "row",
            "layoutTitle": "Enable Cluster mode",
            "type": "switch"
          }
        }
      }
    },
    "etcd": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "order": [
          "replicaCount"
        ],
        "layout": ""
      },
      "properties": {
        "replicaCount": {
          "type": "string",
          "viewSpec": {
            "disabled": true,
            "inputProps": {
              "max": 4,
              "min": 1,
              "suffix": ""
            },
            "layout": "row",
            "layoutTitle": "Number of etcd replicas",
            "type": "rangeinputpicker"
          }
        }
      }
    },
    "gpu_number": {
      "type": "number",
      "viewSpec": {
        "disabled": false,
        "type": "base",
        "layout": "row",
        "layoutTitle": "GPU number",
        "layoutDescription": "Enter the number of GPUs for GPU acceleration. If the number is positive, the node group in the cluster must contain at least this number of VMs with GPUs. If the value is 0 or empty, Milvus will run on vCPUs only."
      },
      "maximum": 8,
      "minimum": 0,
      "format": "int64",
      "validator": "base"
    },
    "minio": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "order": [
          "mode"
        ],
        "layout": ""
      },
      "properties": {
        "mode": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "select",
            "layout": "row",
            "layoutTitle": "Minio mode"
          },
          "enum": [
            "standalone",
            "distributed"
          ]
        }
      }
    },
    "pulsar": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "order": [
          "enabled"
        ],
        "layout": ""
      },
      "properties": {
        "enabled": {
          "type": "boolean",
          "viewSpec": {
            "disabled": false,
            "layout": "row",
            "layoutTitle": "Enable pulsar",
            "type": "switch"
          }
        }
      }
    }
  }
}
