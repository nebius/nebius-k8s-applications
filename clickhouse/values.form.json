{
  "defaultValue": {
    "auth.username": "default",
    "persistence.size": "8Gi"
  },
  "type": "object",
  "viewSpec": {
    "type": "base",
    "layout": "",
    "order": [
      "mk8sCluster",
      "general",
      "auth.username",
      "auth.password",
      "persistence.size"
    ]
  },
  "properties": {
    "mk8sCluster": {
      "type": "object",
      "required": true,
      "viewSpec": {
        "type": "mk8s_cluster"
      }
    },
    "general": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "layout": "section",
        "layoutTitle": "General"
      },
      "defaultValue": {},
      "properties": {
        "appname": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Application name"
          },
          "defaultValue": "clickhouse"
        },
        "namespace": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Namespace"
          },
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "patternError": "namespace must consist of lower case alphanumeric characters or '-', and must start and end with an alphanumeric character (e.g. 'my-name',  or '123-abc', regex used for validation is ^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "defaultValue": "clickhouse"
        }
      }
    },
    "auth.username": {
      "type": "string",
      "required": true,
      "viewSpec": {
        "type": "base",
        "layout": "row",
        "layoutTitle": "ClickHouse Admin username",
        "layoutDescription": "Set administrator username for ClickHouse access."
      }
    },
    "auth.password": {
      "type": "string",
      "required": true,
      "pattern": "^[a-zA-Z0-9-!@#$%^&*]{12,}$",
      "viewSpec": {
        "type": "password",
        "layout": "row",
        "layoutTitle": "ClickHouse admin password",
        "layoutDescription": "Set administrator password for ClickHouse access. Minimum 12 characters with allowed special symbols: !@#$%^&*-",
        "generateRandomValueButton": true
      }
    },
    "persistence.size": {
      "type": "string",
      "required": true,
      "viewSpec": {
        "inputProps": {
          "max": 1000,
          "min": 8,
          "suffix": "Gi"
        },
        "layout": "row",
        "layoutDescription": "Specify a size of data volume.",
        "layoutTitle": "Size",
        "type": "rangeinputpicker"
      }
    }
  }
}
