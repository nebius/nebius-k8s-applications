{
  "type": "object",
  "required": true,
  "viewSpec": {
    "type": "base",
    "order": [
      "mk8sCluster",
      "general",
      "imagePullSecret",
      "nfs",
      "jupyterhub"
    ],
    "layout": ""
  },
  "defaultValue": {
    "nfs": {
      "nfs_pv_size": "2000Gi"
    }
  },
  "properties": {
    "mk8sCluster": {
      "type": "object",
      "required": true,
      "viewSpec": {
        "type": "mk8s_cluster"
      }
    },
    "general": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "layout": "section",
        "layoutTitle": "General"
      },
      "defaultValue": {},
      "properties": {
        "appname": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Application name"
          },
          "defaultValue": "generative-virtual-screening"
        },
        "namespace": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Namespace"
          },
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "patternError": "namespace must consist of lower case alphanumeric characters or '-', and must start and end with an alphanumeric character (e.g. 'my-name',  or '123-abc', regex used for validation is ^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "defaultValue": "generative-virtual-screening"
        }
      }
    },
    "imagePullSecret": {
      "type": "object",
      "required": true,
      "viewSpec": {
        "type": "base",
        "order": [
          "password"
        ],
        "layout": ""
      },
      "defaultValue": {
        "password": ""
      },
      "properties": {
        "password": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "NGC API Key",
            "placeholder": "nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx_xxxxxxxxx",
            "layoutDescription": "Enter the API Key retrived from NGC console with NGC Catalog service included."
          }
        }
      }
    },
    "nfs": {
      "type": "object",
      "required": true,
      "viewSpec": {
        "type": "base",
        "order": [
          "password",
          "nfs_pv_size"
        ],
        "layout": ""
      },
      "properties": {
        "nfs_pv_size": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "inputProps": {
              "max": 10000,
              "min": 1800,
              "suffix": "Gi"
            },
            "layout": "row",
            "layoutDescription": "Specify a disk size for blueprint. Disks do not scale up automatically, so enter a size sufficient for your needs.",
            "layoutTitle": "Disk Size",
            "type": "rangeinputpicker"
          }
        }
      }
    },
    "jupyterhub": {
      "type": "object",
      "required": true,
      "viewSpec": {
        "type": "base",
        "order": [
          "hub",
          "proxy"
        ],
        "layout": ""
      },
      "defaultValue": {
        "prePuller.hook.enabled": false,
        "proxy": {
          "service": {
            "type": "LoadBalancer"
          }
        },
        "singleuser": {
          "storage": {
            "capacity": "50Gi"
          }
        },
        "hub": {
          "config": {
            "DummyAuthenticator": {
              "password": ""
            }
          }
        }
      },
      "properties": {
        "proxy": {
          "type": "object",
          "viewSpec": {
            "type": "base",
            "order": [
              "service"
            ],
            "layout": ""
          },
          "defaultValue": {
            "service": {
              "type": "LoadBalancer"
            }
          },
          "properties": {
            "service": {
              "type": "object",
              "viewSpec": {
                "type": "base",
                "order": [
                  "type"
                ],
                "layout": ""
              },
              "defaultValue": {
                "type": "LoadBalancer"
              },
              "properties": {
                "type": {
                  "type": "string",
                  "required": true,
                  "viewSpec": {
                    "type": "select",
                    "layout": "row",
                    "layoutTitle": "JupyterHub accessibility",
                    "layoutDescription": "Select a way to access the JupyterHub cluster.",
                    "selectParams": {
                      "meta": {
                        "ClusterIP": "Service type: ClusterIP",
                        "LoadBalancer": "Service type: LoadBalancer"
                      }
                    }
                  },
                  "enum": [
                    "LoadBalancer",
                    "ClusterIP"
                  ],
                  "description": {
                    "ClusterIP": "Access only within the cluster.",
                    "LoadBalancer": "Access from the internet and within the cluster"
                  }
                }
              }
            }
          }
        },
        "singleuser": {
          "type": "object",
          "viewSpec": {
            "type": "base",
            "order": [
              "storage"
            ],
            "layout": ""
          },
          "defaultValue": {
            "storage": {
              "capacity": "50Gi"
            }
          },
          "properties": {
            "storage": {
              "type": "object",
              "viewSpec": {
                "type": "base",
                "order": [
                  "capacity"
                ],
                "layout": ""
              },
              "defaultValue": {
                "capacity": "50Gi"
              },
              "properties": {
                "capacity": {
                  "type": "string",
                  "required": true,
                  "viewSpec": {
                    "inputProps": {
                      "max": 1000,
                      "min": 20,
                      "suffix": "Gi"
                    },
                    "layout": "row",
                    "layoutDescription": "Specify a disk size for a notebook server. One user can only have one server and each server has one disk of the specified size. Disks are persistent between restarts: if you start working in one notebook and then switch to another, your work will still be there. Disks do not scale up automatically, so enter a size sufficient for your needs.\n",
                    "layoutTitle": "Size",
                    "type": "rangeinputpicker"
                  }
                }
              }
            }
          }
        },
        "hub": {
          "type": "object",
          "viewSpec": {
            "type": "base",
            "order": [
              "config"
            ],
            "layout": ""
          },
          "properties": {
            "config": {
              "type": "object",
              "viewSpec": {
                "type": "base",
                "order": [
                  "DummyAuthenticator"
                ],
                "layout": ""
              },
              "properties": {
                "DummyAuthenticator": {
                  "type": "object",
                  "viewSpec": {
                    "type": "base",
                    "order": [
                      "password"
                    ],
                    "layout": ""
                  },
                  "properties": {
                    "password": {
                      "type": "string",
                      "required": true,
                      "pattern": "^(?=.*[0-9])(?=.*[a-z])(?=.*[A-Z])(?=.*[*.!@#$%^&*-]).{15,}$",
                      "viewSpec": {
                        "type": "password_generator",
                        "layout": "row",
                        "layoutTitle": "JupyterHub admin password",
                        "layoutDescription": "Set a password for the JupyterHub admin. It must be at least 15 characters long and include a number, a lowercase letter, an uppercase letter, and one of these symbols: !@#$%^&*-",
                        "generateRandomValueButton": true
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
