{
  "type": "object",
  "defaultValue": {},
  "properties": {
    "mk8sCluster": {
      "type": "object",
      "required": true,
      "viewSpec": {
        "type": "mk8s_cluster"
      }
    },
    "general": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "layout": "section",
        "layoutTitle": "General"
      },
      "defaultValue": {},
      "properties": {
        "appname": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Application name"
          },
          "defaultValue": "comfy-ui"
        },
        "namespace": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Namespace"
          },
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "patternError": "namespace must consist of lower case alphanumeric characters or '-', and must start and end with an alphanumeric character (e.g. 'my-name',  or '123-abc', regex used for validation is ^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "defaultValue": "comfy-ui"
        }
      }
    },
    "env": {
      "type": "object",
      "defaultValue": {},
      "properties": {
        "COMFY_TAG": {
          "type": "string",
          "defaultValue": "latest",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Version"
          }
        },
        "MANAGER_TAG": {
          "type": "string",
          "defaultValue": "latest",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Manager version"
          }
        }
      },
      "viewSpec": {
        "type": "base",
        "layout": "transparent",
        "order": [
          "COMFY_TAG",
          "MANAGER_TAG"
        ]
      }
    },
    "resources": {
      "type": "object",
      "defaultValue": {},
      "properties": {
        "gpu_count": {
          "type": "number",
          "format": "int64",
          "minimum": 0,
          "required": true,
          "defaultValue": 1,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "GPU Count"
          }
        },
        "gpu_selector": {
          "type": "string",
          "defaultValue": "any",
          "required": true,
          "enum": [
            "any",
            "gpu-l40s-a",
            "gpu-l40s-d",
            "gpu-h100-sxm",
            "gpu-h200-sxm",
            "gpu-b200-sxm"
          ],
          "description": {
            "any": "Any",
            "gpu-l40s-a": "L40S Intel",
            "gpu-l40s-d": "L40S AMD",
            "gpu-h100-sxm": "H100",
            "gpu-h200-sxm": "H200",
            "gpu-b200-sxm": "B200"
          },
          "viewSpec": {
            "type": "select",
            "layout": "row",
            "layoutTitle": "GPU Type"
          }
        },
        "additional": {
          "type": "object",
          "defaultValue": {},
          "required": true,
          "properties": {
            "cpu": {
              "type": "number",
              "defaultValue": 4,
              "required": true,
              "format": "int64",
              "minimum": 1,
              "viewSpec": {
                "type": "base",
                "layout": "row",
                "layoutTitle": "CPU"
              }
            },
            "memory": {
              "type": "number",
              "defaultValue": 28,
              "required": true,
              "minimum": 1,
              "viewSpec": {
                "type": "base",
                "layout": "row",
                "layoutTitle": "Memory (Gi)"
              }
            },
            "storage_size": {
              "type": "number",
              "defaultValue": 100,
              "required": true,
              "minimum": 1,
              "viewSpec": {
                "type": "base",
                "layout": "row",
                "layoutTitle": "Storage (Gi)"
              }
            }
          },
          "viewSpec": {
            "type": "base",
            "layout": "card_accordeon",
            "layoutTitle": "Additional resources",
            "order": [
              "cpu",
              "memory",
              "storage_size"
            ]
          }
        }
      },
      "viewSpec": {
        "type": "base",
        "layout": "transparent",
        "order": [
          "gpu_count",
          "gpu_selector",
          "additional"
        ]
      }
    }
  },
  "viewSpec": {
    "type": "base",
    "layout": "transparent",
    "order": [
      "mk8sCluster",
      "general",
      "env",
      "resources"
    ]
  }
}
