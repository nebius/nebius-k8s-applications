{
  "type": "object",
  "properties": {
    "mk8sCluster": {
      "type": "object",
      "required": true,
      "viewSpec": {
        "type": "mk8s_cluster"
      }
    },
    "general": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "layout": "section",
        "layoutTitle": "General"
      },
      "defaultValue": {},
      "properties": {
        "appname": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Application name"
          },
          "defaultValue": "ray-cluster"
        },
        "namespace": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Namespace"
          },
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "patternError": "namespace must consist of lower case alphanumeric characters or '-', and must start and end with an alphanumeric character (e.g. 'my-name',  or '123-abc', regex used for validation is ^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "defaultValue": "ray-cluster"
        }
      }
    },
    "kuberay": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "layout": "section",
        "layoutTitle": "KubeRay operator"
      },
      "defaultValue": {},
      "properties": {
        "enabled": {
          "type": "boolean",
          "defaultValue": true,
          "viewSpec": {
            "type": "base",
            "layout": "row_verbose",
            "layoutTitle": "Install version 1.5.1"
          }
        }
      }
    },
    "kube-prometheus-stack": {
      "type": "object",
      "defaultValue": {},
      "properties": {
        "enabled": {
          "type": "boolean",
          "defaultValue": true,
          "viewSpec": {
            "type": "base",
            "layout": "row_verbose",
            "layoutTitle": "Install version 48.2.1"
          }
        },
        "grafana": {
          "type": "object",
          "defaultValue": {},
          "properties": {
            "adminPassword": {
              "type": "string",
              "pattern": "^[a-zA-Z0-9_\\-\\.@]{5,64}$",
              "patternError": "Password must be 8-64 chars, only letters, digits and _-.@",
              "defaultValue": "admin",
              "viewSpec": {
                "type": "password",
                "layout": "row_verbose",
                "layoutTitle": "Grafana admin password"
              }
            }
          },
          "viewSpec": {
            "type": "base",
            "layout": "transparent"
          }
        }
      },
      "viewSpec": {
        "type": "base",
        "layout": "section",
        "layoutTitle": "Kubernetes Prometheus Stack"
