                  "viewSpec": {
                    "type": "select",
                    "layout": "row_verbose",
                    "layoutTitle": "Service type",
                    "selectParams": {
                      "meta": {
                        "ClusterIP": "Access only within the cluster",
                        "LoadBalancer": "Access from the internet and within the cluster"
