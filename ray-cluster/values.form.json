            "ray_version": {
              "type": "string",
              "defaultValue": "2.53.0",
              "required": true,
              "viewSpec": {
                "type": "base",
                "layout": "row_verbose",
                "layoutTitle": "Ray version",
                "placeholder": "Ray version"
              }
            },
            "ray_autoscaling": {
              "type": "object",
              "defaultValue": {},
              "properties": {
                "enable": {
                  "type": "boolean",
                  "defaultValue": true,
                  "viewSpec": {
                    "type": "base",
                    "layout": "row_verbose",
                    "layoutTitle": "Enabled"
                  }
                },
                "advanced": {
                  "type": "object",
                  "defaultValue": {},
                  "required": true,
                  "properties": {
                    "version": {
                      "type": "string",
                      "defaultValue": "v2",
                      "viewSpec": {
                        "type": "base",
                        "layout": "row",
                        "layoutTitle": "version"
                      }
                    },
                    "upscalingMode": {
                      "type": "string",
                      "defaultValue": "Default",
                      "enum": [
                        "Conservative",
                        "Default",
                        "Aggressive"
                      ],
                      "description": {
                        "Conservative": "Conservative",
                        "Default": "Default",
                        "Aggressive": "Aggressive"
                      },
                      "viewSpec": {
                        "type": "select",
                        "layout": "row",
                        "layoutTitle": "upscalingMode",
                        "selectParams": {
                          "meta": {
                            "Conservative": "Upscaling is rate-limited; the number of pending worker Pods is at most the number of worker pods connected to the Ray cluster.",
                            "Default": "Upscaling isn’t rate-limited.",
                            "Aggressive": "An alias for Default; upscaling isn’t rate-limited."
                          }
                        }
                      }
                    },
                    "idleTimeoutSeconds": {
                      "type": "number",
                      "defaultValue": 60,
                      "minimum": 0,
                      "viewSpec": {
                        "type": "base",
                        "layout": "row",
                        "layoutTitle": "idleTimeoutSeconds"
                      }
                    }
                  },
                  "viewSpec": {
                    "type": "base",
                    "layout": "card_accordeon",
                    "layoutTitle": "Advanced",
                    "order": [
                      "version",
                      "upscalingMode",
                      "idleTimeoutSeconds"
                    ]
                  }
                }
              },
              "viewSpec": {
                "type": "base",
                "layout": "section",
                "layoutTitle": "Autoscaling",
                "order": [
                  "enable",
                  "advanced"
                ]
              }
            },
