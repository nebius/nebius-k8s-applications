{
  "type": "object",
  "viewSpec": {
    "type": "base",
    "order": [
      "mk8sCluster",
      "general",
      "config",
      "postgresql",
      "mariadb"
    ],
    "layout": ""
  },
  "defaultValue": {
    "config": {
      "password": "",
      "username": ""
    },
    "mariadb": {
      "enabled": false
    },
    "postgresql": {
      "enabled": true
    }
  },
  "properties": {
    "mk8sCluster": {
      "type": "object",
      "required": true,
      "viewSpec": {
        "type": "mk8s_cluster"
      }
    },
    "general": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "layout": "section",
        "layoutTitle": "General"
      },
      "defaultValue": {},
      "properties": {
        "appname": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Application name"
          },
          "defaultValue": "flowise"
        },
        "namespace": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Namespace"
          },
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "patternError": "namespace must consist of lower case alphanumeric characters or '-', and must start and end with an alphanumeric character (e.g. 'my-name',  or '123-abc', regex used for validation is ^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
          "defaultValue": "flowise"
        }
      }
    },
    "config": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "order": [
          "username",
          "password"
        ],
        "layout": ""
      },
      "properties": {
        "password": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "disabled": false,
            "generateRandomValueButton": true,
            "layout": "row",
            "layoutTitle": "Password",
            "layoutDescription": "Create a password for the user name.",
            "type": "password"
          },
          "pattern": "^[a-zA-Z0-9-!@#\\$%\\^&*]{8,}$"
        },
        "username": {
          "type": "string",
          "required": true,
          "viewSpec": {
            "type": "base",
            "layout": "row",
            "layoutTitle": "Username",
            "layoutDescription": "Create a user name to access Flowise UI."
          }
        }
      }
    },
    "mariadb": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "order": [
          "enabled"
        ],
        "layout": ""
      },
      "properties": {
        "enabled": {
          "type": "boolean",
          "viewSpec": {
            "disabled": false,
            "layout": "row",
            "layoutTitle": "Enable MariaDB",
            "layoutDescription": "Select PostgreSQL support. It is recommended to select this database.",
            "type": "switch"
          }
        }
      }
    },
    "postgresql": {
      "type": "object",
      "viewSpec": {
        "type": "base",
        "order": [
          "enabled"
        ],
        "layout": ""
      },
      "properties": {
        "enabled": {
          "type": "boolean",
          "viewSpec": {
            "disabled": false,
            "layout": "row",
            "layoutTitle": "Enable PostgreSQL",
            "layoutDescription": "Select MariaDB support instead if for any reason PostgreSQL support is not applicable.",
            "type": "switch"
          }
        }
      }
    }
  }
}
